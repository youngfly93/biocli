{
  "name": "@yangfei_93sky/biocli",
  "version": "0.7.1",
  "description": "Batch gene scanning, tumor cohort briefing, and target discovery for agent-driven biology workflows",
  "type": "module",
  "main": "dist/main.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "biocli": "dist/main.js",
    "ncbicli": "dist/main.js"
  },
  "exports": {
    ".": "./dist/main.js",
    "./bootstrap": "./dist/bootstrap.js",
    "./mcp-core": "./dist/mcp-core.js",
    "./registry": "./dist/registry-api.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "npm run clean-dist && tsc -p tsconfig.build.json && npm run clean-yaml && npm run copy-yaml && npm run build-manifest && npm run clean-apple-double",
    "build:conda:local": "bash scripts/build-conda-local.sh",
    "clean-apple-double": "node scripts/clean-apple-double.cjs",
    "build-manifest": "node dist/build-manifest.js",
    "clean-dist": "node scripts/clean-dist.cjs",
    "clean-yaml": "node scripts/clean-yaml.cjs",
    "copy-yaml": "node scripts/copy-yaml.cjs",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "verify:conda": "node scripts/verify-conda-scaffold.cjs",
    "bench:pipeline": "tsx benchmarks/pipeline/run.ts",
    "bench:pipeline:resume": "tsx benchmarks/pipeline/resume.ts",
    "bench:pipeline:report": "tsx benchmarks/pipeline/report.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run --project unit --passWithNoTests",
    "test:adapter": "vitest run --project adapter --passWithNoTests",
    "test:e2e": "vitest run --project e2e --passWithNoTests",
    "test:smoke": "vitest run --project smoke --passWithNoTests",
    "test:coverage": "vitest run --coverage --passWithNoTests",
    "test:all": "vitest run --passWithNoTests",
    "smoke:core": "bash scripts/smoke-core.sh",
    "smoke:live": "bash scripts/smoke-live.sh"
  },
  "keywords": [
    "agent",
    "batch",
    "cancer",
    "cbioportal",
    "ncbi",
    "opentargets",
    "pubmed",
    "bioinformatics",
    "cli",
    "gene",
    "geo",
    "sra",
    "target-discovery",
    "tumor"
  ],
  "author": "youngfly93",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/youngfly93/biocli.git"
  },
  "homepage": "https://github.com/youngfly93/biocli#readme",
  "bugs": {
    "url": "https://github.com/youngfly93/biocli/issues"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "fast-xml-parser": "^4.5.0",
    "js-yaml": "^4.1.0",
    "undici": "^8.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^4.1.4",
    "tsx": "^4.19.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
